<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-5.0.xsd"
        objectQuotingStrategy="QUOTE_ONLY_RESERVED_WORDS">
    <changeSet id="1775914890276-1" author="user">
        <addColumn tableName="production_records">
            <column name="adapter_id" type="BIGINT"/>
        </addColumn>
    </changeSet>
    <changeSet id="1775914890276-2" author="Пользователь">
        <addForeignKeyConstraint baseColumnNames="adapter_id" baseTableName="production_records"
                                 constraintName="FK_PRODUCTION_RECORDS_ON_ADAPTER" referencedColumnNames="id"
                                 referencedTableName="pipe_adapters_data"/>
    </changeSet>
    <changeSet id="1775914890276-3" author="Пользователь">
        <addForeignKeyConstraint baseColumnNames="coupling_id" baseTableName="production_records"
                                 constraintName="FK_PRODUCTION_RECORDS_ON_COUPLING" referencedColumnNames="id"
                                 referencedTableName="couplings_data"/>
    </changeSet>
    <changeSet id="1775914890276-4" author="Пользователь">
        <addForeignKeyConstraint baseColumnNames="employee_id" baseTableName="production_records"
                                 constraintName="FK_PRODUCTION_RECORDS_ON_EMPLOYEE" referencedColumnNames="id"
                                 referencedTableName="list_employees"/>
    </changeSet>
    <changeSet id="1775914890276-5" author="Пользователь">
        <addForeignKeyConstraint baseColumnNames="machine_id" baseTableName="production_records"
                                 constraintName="FK_PRODUCTION_RECORDS_ON_MACHINE" referencedColumnNames="id"
                                 referencedTableName="list_machines"/>
    </changeSet>

    <changeSet id="20250320120000-3" author="system">
        <comment>Снимаем NOT NULL с coupling_id в production_records</comment>
        <dropNotNullConstraint tableName="production_records"
                               columnName="coupling_id"
                               columnDataType="BIGINT"/>
    </changeSet>

</databaseChangeLog>